---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import PostList from '../../components/PostList.astro';
import { SITE_TITLE } from '../../consts';
import { getAllTags, getSortedPosts, slugify } from '../../lib/taxonomy';

export async function getStaticPaths() {
	const tags = await getAllTags();
	return tags.map(({ tag, slug }) => ({
		params: { tag: slug },
		props: { tag },
	}));
}

const { tag } = Astro.props;
const posts = (await getSortedPosts()).filter((post) =>
	post.data.tags?.some((t) => slugify(t) === slugify(tag)),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`#${tag} — ${SITE_TITLE}`} description={`Posts tagged #${tag}.`} />
	</head>
	<body>
		<Header />
		<main class="prose">
			<h1>#{tag}</h1>
			<PostList posts={posts} />
		</main>
		<Footer />
	</body>
</html>

<style>
	.prose {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em;
	}
</style>
