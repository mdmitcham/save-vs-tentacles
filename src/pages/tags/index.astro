---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';
import { getAllTags } from '../../lib/taxonomy';

const tags = await getAllTags();
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Tags — ${SITE_TITLE}`} description="All tags." />
	</head>
	<body>
		<Header />
		<main class="prose">
			<h1>Tags</h1>
			<ul class="tag-cloud">
				{
					tags.map(({ tag, slug, count }) => (
						<li>
							<a href={`/tags/${slug}/`}>
								#{tag} <span class="count">({count})</span>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	.prose {
		width: 720px;
		max-width: calc(100% - 2em);
		margin: auto;
		padding: 1em;
	}
	.tag-cloud {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 1em;
	}
	.tag-cloud a {
		text-decoration: none;
		color: rgb(var(--black));
		font-size: 1.1em;
	}
	.tag-cloud a:hover {
		color: rgb(var(--accent));
	}
	.count {
		color: rgb(var(--gray));
		font-size: 0.85em;
	}
</style>
